# ─────────────────────────────────────────────────────────────────────────────
# Automatic Parking Booker — Variables de entorno
# Copia este archivo a .env y completá los valores
# ─────────────────────────────────────────────────────────────────────────────

# Número de WhatsApp del canal de cocheras
# Formato: código de país + código de área + número + @c.us
# Ejemplo Argentina (+54 9 351 XXX XXXX): 5493512345678@c.us
COCHERA_PHONE_NUMBER=5493510000000@c.us

# Topic de ntfy para notificaciones push
# Elige un nombre único (lo que sea), y suscribite a ese mismo topic en la app ntfy
# Recomendación: algo como "cochera-tomi-<numero_random>" para evitar colisiones
NTFY_TOPIC=cochera-tomi

# (Opcional) URL de ntfy — si tenés instancia propia, cambiá esto
# Por defecto usa la instancia pública de ntfy.sh
NTFY_BASE_URL=https://ntfy.sh

# (Opcional) Nivel de logs: DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO
